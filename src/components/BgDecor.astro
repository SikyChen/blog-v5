---
// siky.top 风格的几何动画背景装饰：菱形/圆/三角/方块/横线漂浮
// 纯 CSS 动画，无 JS。样式见 src/styles/global.css 的 @layer hub.bg 段。
---
<div class="bg-decor" aria-hidden="true" transition:persist="bg-decor">
	<div class="diamond diamond-1"></div>
	<div class="diamond diamond-2"></div>
	<div class="diamond diamond-3"></div>
	<div class="diamond diamond-4"></div>
	<div class="diamond diamond-5"></div>
	<div class="circle circle-1"></div>
	<div class="circle circle-2"></div>
	<div class="circle circle-3"></div>
	<div class="circle circle-4"></div>
	<div class="triangle triangle-1"></div>
	<div class="triangle triangle-2"></div>
	<div class="triangle triangle-3"></div>
	<div class="square square-1"></div>
	<div class="square square-2"></div>
	<div class="square square-3"></div>
	<div class="line-decor line-decor-1"></div>
	<div class="line-decor line-decor-2"></div>
	<div class="line-decor line-decor-3"></div>
</div>
