---
const today = new Date();
---

<footer>
	<div class="hex-decor">0x7B 0x2E 0x48 0x55 0x42</div>
	<p class="copyright">&copy; {today.getFullYear()} SIKY_HUB · Built with Astro</p>
</footer>
<style>
	footer {
		position: relative;
		z-index: 1;
		padding: 2em 1em 4em;
		text-align: center;
		font-family: var(--font-mono);
		color: var(--hub-fg);
	}
	.hex-decor {
		font-size: 0.9rem;
		opacity: 0.5;
		letter-spacing: 5px;
		margin-bottom: 0.8em;
	}
	.copyright {
		margin: 0;
		font-size: 0.85rem;
		opacity: 0.7;
		letter-spacing: 1px;
	}
</style>
