---
import type { CollectionEntry, MarkdownHeading } from 'astro:content';
import { Image } from 'astro:assets';
import FormattedDate from '../components/FormattedDate.astro';
import PostCover from '../components/PostCover.astro';
import HubLayout from './HubLayout.astro';

type PostData = CollectionEntry<'blog'>['data'];
type Props = PostData & {
	headings?: MarkdownHeading[];
	readingTime?: number;
	prev?: { id: string; title: string };
	next?: { id: string; title: string };
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags,
	headings,
	readingTime,
	prev,
	next,
} = Astro.props;
// 仅 h2/h3 进目录
const tocHeadings = (headings ?? []).filter((h) => h.depth === 2 || h.depth === 3);
---

<HubLayout title={title} description={description ?? ''} image={heroImage}>
	<!-- 阅读进度条 -->
	<div class="reading-progress" id="reading-progress"></div>

	<article class="post">
		<div class="post-head">
			<h1 class="post-title">{title}</h1>
			<div class="post-meta">
				<FormattedDate date={pubDate} />
				{readingTime && <span class="meta-sep">· 约 {readingTime} 分钟</span>}
			</div>
			{
				tags && tags.length > 0 && (
					<div class="post-tags">
						{tags.map((tag) => (
							<a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>
								#{tag}
							</a>
						))}
					</div>
				)
			}
			<div class="title-line"></div>
		</div>

		{
			heroImage ? (
				<div class="hero-image">
					<Image width={1020} height={510} src={heroImage} alt="" />
				</div>
			) : (
				<div class="hero-image">
					<PostCover title={title} tags={tags} />
				</div>
			)
		}

		<div class="prose">
			<slot />
		</div>

		{
			(prev || next) && (
				<nav class="post-nav">
					{prev ? (
						<a class="nav-prev" href={`/blog/${prev.id}/`}>
							<span class="nav-label">← 上一篇</span>
							<span class="nav-title">{prev.title}</span>
						</a>
					) : (
						<span />
					)}
					{next ? (
						<a class="nav-next" href={`/blog/${next.id}/`}>
							<span class="nav-label">下一篇 →</span>
							<span class="nav-title">{next.title}</span>
						</a>
					) : (
						<span />
					)}
				</nav>
			)
		}
	</article>

	<!-- 浮动 TOC(目录) -->
	{
		tocHeadings.length > 0 && (
			<>
				<button class="toc-toggle" id="toc-toggle" type="button" aria-label="打开目录" title="目录">
					<svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
						<path
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							d="M4 6h16M4 12h10M4 18h7"
						/>
					</svg>
				</button>
				<aside class="toc-panel" id="toc-panel">
					<div class="toc-head">目录</div>
					<ul>
						{tocHeadings.map((h) => (
							<li class={h.depth === 3 ? 'toc-h3' : 'toc-h2'}>
								<a href={`#${h.slug}`}>{h.text}</a>
							</li>
						))}
					</ul>
				</aside>
			</>
		)
	}

	<!-- 回到顶部 -->
	<button class="back-to-top" id="back-to-top" type="button" aria-label="回到顶部" title="回到顶部">
		<svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22"
			><path
				fill="none"
				stroke="currentColor"
				stroke-width="2.5"
				stroke-linecap="round"
				stroke-linejoin="round"
				d="M12 19V5M5 12l7-7 7 7"
			/></svg
		>
	</button>

	<script>
		function setupArticle() {
			const progress = document.getElementById('reading-progress');
			if (!progress) return; // 非文章页

			const backTop = document.getElementById('back-to-top');
			const tocToggle = document.getElementById('toc-toggle');
			const tocPanel = document.getElementById('toc-panel');

			// 阅读进度 + 回到顶部显隐
			const onScroll = () => {
				const h = document.documentElement;
				const max = h.scrollHeight - h.clientHeight;
				const pct = max > 0 ? (h.scrollTop / max) * 100 : 0;
				progress.style.width = pct + '%';
				backTop?.classList.toggle('visible', h.scrollTop > 600);
			};
			window.addEventListener('scroll', onScroll, { passive: true });
			onScroll();

			backTop?.addEventListener('click', () =>
				window.scrollTo({ top: 0, behavior: 'smooth' })
			);

			// 代码块复制按钮
			document.querySelectorAll<HTMLElement>('.prose pre').forEach((pre) => {
				if (pre.querySelector('.copy-btn')) return;
				const btn = document.createElement('button');
				btn.className = 'copy-btn';
				btn.type = 'button';
				btn.setAttribute('aria-label', '复制代码');
				btn.textContent = '复制';
				btn.addEventListener('click', async () => {
					const code = pre.querySelector('code')?.textContent ?? '';
					try {
						await navigator.clipboard.writeText(code);
						btn.textContent = '已复制';
						btn.classList.add('copied');
						setTimeout(() => {
							btn.textContent = '复制';
							btn.classList.remove('copied');
						}, 1500);
					} catch (e) {
						btn.textContent = '失败';
						setTimeout(() => {
							btn.textContent = '复制';
						}, 1500);
					}
				});
				pre.appendChild(btn);
			});

			// TOC 开关
			let tocOpen = false;
			const closeToc = () => {
				tocOpen = false;
				tocPanel?.classList.remove('open');
				tocToggle?.classList.remove('open');
			};
			tocToggle?.addEventListener('click', () => {
				tocOpen = !tocOpen;
				tocPanel?.classList.toggle('open', tocOpen);
				tocToggle.classList.toggle('open', tocOpen);
			});
			tocPanel?.querySelectorAll('a').forEach((a) =>
				a.addEventListener('click', () => closeToc())
			);

			// 滚动高亮当前章节
			const headings = Array.from(
				document.querySelectorAll<HTMLElement>('.prose h2, .prose h3')
			);
			const tocLinks = Array.from(tocPanel?.querySelectorAll('a') ?? []);
			let observer: IntersectionObserver | null = null;
			if (headings.length && tocLinks.length) {
				const visible = new Set<string>();
				observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((e) => {
							if (e.isIntersecting) visible.add(e.target.id);
							else visible.delete(e.target.id);
						});
						let activeId: string | null = null;
						for (const h of headings) {
							if (visible.has(h.id)) {
								activeId = h.id;
								break;
							}
						}
						tocLinks.forEach((l) =>
							l.classList.toggle('active', l.getAttribute('href') === '#' + activeId)
						);
					},
					{ rootMargin: '0px 0px -70% 0px', threshold: 0 }
				);
				headings.forEach((h) => observer.observe(h));
			}

			const onKey = (e: KeyboardEvent) => {
				if (e.key === 'Escape') closeToc();
			};
			document.addEventListener('keydown', onKey);

			// view transition 前清理
			document.addEventListener(
				'astro:before-swap',
				() => {
					window.removeEventListener('scroll', onScroll);
					document.removeEventListener('keydown', onKey);
					observer?.disconnect();
				},
				{ once: true }
			);
		}
		document.addEventListener('astro:page-load', setupArticle);
	</script>
</HubLayout>

<style>
	.post {
		width: 100%;
		margin: 0 auto;
		padding: 2em 2.5em 1em;
		background: var(--hub-article-bg);
		border: 1px solid var(--hub-border);
		border-radius: 6px;
		backdrop-filter: blur(3px);
	}
	.post-head {
		text-align: center;
		margin-bottom: 2em;
	}
	.post-title {
		font-size: clamp(1.6rem, 4vw, 2.4rem);
		font-weight: 900;
		letter-spacing: 2px;
		color: var(--hub-fg);
		margin: 0 0 0.5em;
		line-height: 1.3;
	}
	.post-meta {
		font-size: 0.85rem;
		color: var(--hub-blue);
		letter-spacing: 1px;
	}
	.updated {
		opacity: 0.7;
	}
	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		justify-content: center;
		margin-top: 1em;
	}
	.post-tags .tag {
		font-size: 0.78rem;
		letter-spacing: 1px;
		color: var(--hub-blue);
		text-decoration: none;
		padding: 0.2em 0.7em;
		border: 1px solid rgba(0, 168, 217, 0.4);
		border-radius: 2px;
		transition: all 0.2s ease;
	}
	.post-tags .tag:hover {
		color: var(--hub-bg);
		background: var(--hub-blue);
		border-color: var(--hub-blue);
	}
	.title-line {
		width: 60px;
		height: 4px;
		background: var(--hub-yellow);
		margin: 1.2em auto 0;
	}
	.hero-image {
		margin-bottom: 2em;
	}
	.hero-image :global(img) {
		display: block;
		margin: 0 auto;
		border-radius: 4px;
		border: 2px solid var(--hub-border);
	}
	.post-nav {
		display: flex;
		justify-content: space-between;
		gap: 1.5em;
		margin-top: 3em;
		padding-top: 1.5em;
		border-top: 2px solid var(--hub-decor);
	}
	.post-nav a {
		display: flex;
		flex-direction: column;
		gap: 0.3em;
		text-decoration: none;
		color: var(--hub-fg);
		padding: 0.8em 1em;
		border: 2px solid var(--hub-border);
		background: var(--hub-card-bg);
		transition: all 0.3s ease;
		max-width: 48%;
	}
	.post-nav a:hover {
		border-color: var(--hub-yellow);
		color: var(--hub-yellow);
	}
	.nav-next {
		text-align: right;
		margin-left: auto;
	}
	.nav-label {
		font-size: 0.78rem;
		letter-spacing: 2px;
		color: var(--hub-blue);
	}
	.nav-title {
		font-size: 0.95rem;
		font-weight: 700;
	}
	@media (max-width: 720px) {
		.post {
			padding: 1.5em 1.2em 1em;
		}
		.post-nav {
			flex-direction: column;
		}
		.post-nav a {
			max-width: 100%;
		}
		.nav-next {
			text-align: left;
			margin-left: 0;
		}
	}

	/* 阅读进度条 */
	.reading-progress {
		position: fixed;
		top: 0;
		left: 0;
		height: 3px;
		width: 0;
		background: var(--hub-yellow);
		z-index: 100;
		transition: width 0.1s linear;
		will-change: width;
	}

	/* 回到顶部 */
	.back-to-top {
		position: fixed;
		right: 24px;
		bottom: 24px;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		padding: 0;
		border: 1px solid var(--hub-border);
		border-radius: 4px;
		background: var(--hub-article-bg);
		backdrop-filter: blur(4px);
		color: var(--hub-fg);
		cursor: pointer;
		opacity: 0;
		visibility: hidden;
		transform: translateY(10px);
		transition: all 0.3s ease;
		z-index: 90;
	}
	.back-to-top.visible {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}
	.back-to-top:hover {
		color: var(--hub-yellow);
		border-color: var(--hub-yellow);
	}

	/* 浮动 TOC */
	.toc-toggle {
		position: fixed;
		left: 24px;
		bottom: 24px;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		padding: 0;
		border: 1px solid var(--hub-border);
		border-radius: 4px;
		background: var(--hub-article-bg);
		backdrop-filter: blur(4px);
		color: var(--hub-fg);
		cursor: pointer;
		transition: all 0.2s ease;
		z-index: 90;
	}
	.toc-toggle:hover,
	.toc-toggle.open {
		color: var(--hub-yellow);
		border-color: var(--hub-yellow);
	}
	.toc-panel {
		position: fixed;
		left: 24px;
		bottom: 76px;
		width: 260px;
		max-height: 60vh;
		overflow-y: auto;
		padding: 1em 1.2em;
		background: var(--hub-article-bg);
		backdrop-filter: blur(6px);
		border: 1px solid var(--hub-border);
		border-radius: 6px;
		opacity: 0;
		visibility: hidden;
		transform: translateY(10px);
		transition: all 0.25s ease;
		z-index: 91;
		font-family: var(--font-mono);
	}
	.toc-panel.open {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}
	.toc-head {
		font-size: 0.8rem;
		letter-spacing: 3px;
		color: var(--hub-yellow);
		margin-bottom: 0.6em;
		padding-bottom: 0.4em;
		border-bottom: 1px solid var(--hub-decor);
	}
	.toc-panel ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.2em;
	}
	.toc-panel a {
		display: block;
		padding: 0.3em 0.5em;
		font-size: 0.82rem;
		line-height: 1.4;
		color: var(--hub-fg-soft);
		text-decoration: none;
		border-left: 2px solid transparent;
		transition: all 0.2s ease;
	}
	.toc-panel .toc-h3 a {
		padding-left: 1.5em;
		font-size: 0.78rem;
	}
	.toc-panel a:hover {
		color: var(--hub-fg);
	}
	.toc-panel a.active {
		color: var(--hub-yellow);
		border-left-color: var(--hub-yellow);
		font-weight: 700;
	}
	@media (max-width: 720px) {
		.toc-panel {
			width: calc(100vw - 48px);
		}
	}
</style>
